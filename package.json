{
  "name": "react-native-glass",
  "version": "0.2.4",
  "description": "A high-quality frosted glass blur effect for React Native — iOS UIVisualEffectView + Android PixelCopy. Dark & Light themes, smooth intensity control, Old & New Architecture support.",
  "main": "src/index",
  "module": "src/index",
  "react-native": "src/index",
  "source": "src/index",
  "types": "src/index.d.ts",
  "files": [
    "src",
    "android",
    "ios",
    "react-native-glass.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\""
  },
  "keywords": [
    "react-native",
    "blur",
    "glass",
    "frosted",
    "frosted-glass",
    "blur-view",
    "glass-view",
    "visual-effect",
    "backdrop-blur",
    "ios",
    "android",
    "ui",
    "overlay",
    "dark",
    "light",
    "effect",
    "native",
    "component",
    "view",
    "transparency"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aditya886/react-native-glass.git"
  },
  "author": "Aditya <adiaditya144@gmail.com> (https://github.com/aditya886)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aditya886/react-native-glass/issues"
  },
  "homepage": "https://github.com/aditya886/react-native-glass#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "typescript": "^5.0.0"
  }
}